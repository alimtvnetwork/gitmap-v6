<#
.SYNOPSIS
    Clone all repositories from a gitmap scan.
.DESCRIPTION
    Auto-generated by gitmap. Run this script to clone all
    discovered repositories, preserving the original folder structure.
#>

param(
    [string]$TargetDir = "."
)

$ErrorActionPreference = "Stop"
Set-Location $TargetDir

# ── Repository data ───────────────────────────────────────────
$repos = @(
{{- range .Repos }}
    @{ Name = "{{ .Name }}"; Branch = "{{ .Branch }}"; URL = "{{ .URL }}"; Path = "{{ .Path }}" }
{{- end }}
)

# ── Banner ────────────────────────────────────────────────────
Write-Host ""
Write-Host "  +======================================+" -ForegroundColor DarkCyan
Write-Host "  |          gitmap clone script         |" -ForegroundColor DarkCyan
Write-Host "  +======================================+" -ForegroundColor DarkCyan
Write-Host ""
Write-Host "  Cloning $($repos.Count) repositories..." -ForegroundColor Cyan
Write-Host ""

# ── Clone loop ────────────────────────────────────────────────
$succeeded = 0
$failed = 0
$index = 0

foreach ($repo in $repos) {
    $index++
    Write-Host "  [$index/$($repos.Count)] " -ForegroundColor Magenta -NoNewline
    Write-Host $repo.Name -ForegroundColor White

    $parentDir = Split-Path $repo.Path -Parent
    if ($parentDir -and -not (Test-Path $parentDir)) {
        New-Item -ItemType Directory -Path $parentDir -Force | Out-Null
    }

    $cloneResult = git clone -b $repo.Branch $repo.URL $repo.Path 2>&1
    if ($LASTEXITCODE -eq 0) {
        Write-Host "  OK Cloned successfully" -ForegroundColor Green
        $succeeded++
    } else {
        Write-Host "  XX Clone failed: $cloneResult" -ForegroundColor Red
        $failed++
    }
}

# ── Summary ───────────────────────────────────────────────────
Write-Host ""
Write-Host "  ======================================" -ForegroundColor DarkCyan
Write-Host "  OK Succeeded: $succeeded" -ForegroundColor Green
Write-Host "  XX Failed:    $failed" -ForegroundColor Red
Write-Host "  ======================================" -ForegroundColor DarkCyan
Write-Host ""
Write-Host "  Done!" -ForegroundColor Green
Write-Host ""
