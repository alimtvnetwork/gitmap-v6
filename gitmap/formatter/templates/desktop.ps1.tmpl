<#
.SYNOPSIS
    Register cloned repositories with GitHub Desktop.
.DESCRIPTION
    Auto-generated by gitmap. Run this script after cloning
    to add all repositories to GitHub Desktop.
    Requires GitHub Desktop CLI (github) to be available in PATH.
#>

param(
    [string]$BaseDir = "."
)

# ── Check GitHub Desktop CLI ─────────────────────────────────
$ghDesktop = Get-Command "github" -ErrorAction SilentlyContinue
if (-not $ghDesktop) {
    Write-Host ""
    Write-Host "  XX GitHub Desktop CLI not found." -ForegroundColor Red
    Write-Host "    Install GitHub Desktop and ensure 'github' is in your PATH." -ForegroundColor Yellow
    Write-Host ""
    exit 1
}

# ── Repository data ───────────────────────────────────────────
$repos = @(
{{- range .Repos }}
    @{ Name = "{{ .Name }}"; Path = "{{ .Path }}" }
{{- end }}
)

# ── Banner ────────────────────────────────────────────────────
Write-Host ""
Write-Host "  +======================================+" -ForegroundColor DarkCyan
Write-Host "  |     gitmap -- GitHub Desktop         |" -ForegroundColor DarkCyan
Write-Host "  +======================================+" -ForegroundColor DarkCyan
Write-Host ""
Write-Host "  Registering $($repos.Count) repositories..." -ForegroundColor Cyan
Write-Host ""

# ── Registration loop ─────────────────────────────────────────
$succeeded = 0
$failed = 0
$index = 0

foreach ($repo in $repos) {
    $index++
    Write-Host "  [$index/$($repos.Count)] " -ForegroundColor Magenta -NoNewline
    Write-Host $repo.Name -ForegroundColor White

    $repoPath = Join-Path $BaseDir $repo.Path
    $repoPath = (Resolve-Path $repoPath -ErrorAction SilentlyContinue).Path

    if ($repoPath -and (Test-Path $repoPath)) {
        try {
            github $repoPath 2>&1 | Out-Null
            Write-Host "  OK Added to GitHub Desktop" -ForegroundColor Green
            $succeeded++
        } catch {
            Write-Host "  XX Failed: $_" -ForegroundColor Red
            $failed++
        }
    } else {
        Write-Host "  XX Path not found: $($repo.Path)" -ForegroundColor Red
        $failed++
    }
}

# ── Summary ───────────────────────────────────────────────────
Write-Host ""
Write-Host "  ======================================" -ForegroundColor DarkCyan
Write-Host "  OK Registered: $succeeded" -ForegroundColor Green
Write-Host "  XX Failed:     $failed" -ForegroundColor Red
Write-Host "  ======================================" -ForegroundColor DarkCyan
Write-Host ""
Write-Host "  Done!" -ForegroundColor Green
Write-Host ""
